{
  "schemaVersion": 1,
  "id": "${mod_id}",
  "version": "${mod_version}",
  "name": "${mod_name}",
  "description": "${mod_description}",
  "authors": [
    {
      "name": "D4rkSwift/Saotzuri",
      "contact": {
        "homepage": "https://github.com/Saotzuri"
      }
    },
    {
      "name": "RolexDE",
      "contact": {
        "homepage": "https://github.com/RolexDE"
      }
    }
  ],
  "contact": {
    "homepage": "https://skyblockoverhaul.com",
    "sources": "https://github.com/SkyblockOverhaul/SBO",
    "issues": "https://github.com/SkyblockOverhaul/SBO/issues"
  },
  "license": "Apache-2.0",
  "icon": "assets/sbo/icon.png",
  "environment": "client",
  "entrypoints": {
    "client": [
      {
        "adapter": "kotlin",
        "value": "${mod_group}.SBOKotlin"
      }
    ]
  },
  "mixins": [
    {
      "config": "sbo.mixins.json",
      "environment": "client"
    }
  ],
  "accessWidener": "sbo.classtweaker",
  "depends": {
    "fabricloader": ">=${fabric_loader_version}",
    "minecraft": "${mc_version_constraint}",
    "java": ">=${java_version_major}",
    "fabric-api": ">=${fabric_api_version}",
    "fabric-language-kotlin": ">=${fabric_language_kotlin_version}",
    "elementa": ">=${elementa_version}",
    "hm-api": ">=${hm_api_version}",
    "resourcefulconfig": ">=${resourcefulconfig_version}",
    "resourcefulconfigkt": ">=${resourcefulconfigkt_version}",
    "universalcraft": ">=${universalcraft_version}"
  },
  "custom": {
    "modmenu": {
      "update_checker": true,
      "links": {
        "modmenu.website": "https://skyblockoverhaul.com/",
        "modmenu.patreon": "https://www.patreon.com/Skyblock_Overhaul",
        "modmenu.discord": "https://discord.com/invite/QvM6b9jsJD",
        "modmenu.github_releases": "https://github.com/SkyblockOverhaul/SBO/releases",
        "modmenu.modrinth": "https://modrinth.com/mod/skyblock-overhaul"
      }
    }
  }
}
